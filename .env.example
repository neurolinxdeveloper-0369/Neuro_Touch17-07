# ==========================================
# Neuro Touch Smart Home IoT Server config
# ==========================================

# Port the backend Fiber app listens on (default: 8080)
PORT=8080

# --- PostgreSQL Connection Parameters ---
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=neurotouch
DB_SSLMODE=disable

# --- EMQX MQTT Connection Parameters ---
MQTT_BROKER=emqx
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# --- JWT Signing Key ---
# Change this to a secure random string in production
JWT_SECRET=super_secret_neuro_touch_key

# --- Local Ollama AI Setup ---
OLLAMA_API_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# --- OAuth2 Credentials Placeholders ---
# Replace these with your registered app client IDs
GOOGLE_CLIENT_ID=placeholder_google_client_id
APPLE_CLIENT_ID=placeholder_apple_client_id
